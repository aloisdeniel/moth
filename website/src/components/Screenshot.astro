---
/**
 * Screenshot slot with a stable path under public/screenshots/ — images are
 * generated in CI from a seeded demo instance (plan/09), so the build (and
 * the layout) must work before they exist. A fixed aspect-ratio frame
 * reserves the space (zero CLS); when the image is missing, the frame shows
 * a quiet labelled empty state instead of a broken image.
 */
interface Props {
  /** Path under the site root, e.g. "/screenshots/projects.png". */
  src: string;
  alt: string;
  /** Mono label shown while the screenshot is missing. */
  label: string;
  ratio?: string;
}

const { src, alt, label, ratio = '16 / 10' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<figure class="shot" style={`aspect-ratio: ${ratio};`}>
  <span class="shot-empty" aria-hidden="true">{label}</span>
  <img src={`${base}${src}`} alt={alt} loading="lazy" decoding="async" />
</figure>

<script>
  // A missing screenshot leaves the styled empty state visible.
  document.querySelectorAll<HTMLImageElement>('.shot img').forEach((img) => {
    const missing = () => img.closest('.shot')?.classList.add('shot-missing');
    if (img.complete && img.naturalWidth === 0) missing();
    img.addEventListener('error', missing);
  });
</script>
