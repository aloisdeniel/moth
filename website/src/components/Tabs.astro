---
/**
 * Accessible tabs (DESIGN.md underline style). Content goes into named
 * slots, one per tab id. Progressive: without JS the first panel shows.
 */
interface Tab {
  id: string;
  label: string;
}

interface Props {
  /** Unique per page — namespaces the tab/panel element ids. */
  name: string;
  tabs: Tab[];
}

const { name, tabs } = Astro.props;
---

<div class="tabs" data-tabs>
  <div class="tablist" role="tablist" aria-label={name}>
    {
      tabs.map((tab, i) => (
        <button
          type="button"
          role="tab"
          id={`tab-${name}-${tab.id}`}
          aria-controls={`panel-${name}-${tab.id}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          tabindex={i === 0 ? 0 : -1}
        >
          {tab.label}
        </button>
      ))
    }
  </div>
  {
    tabs.map((tab, i) => (
      <div
        role="tabpanel"
        id={`panel-${name}-${tab.id}`}
        aria-labelledby={`tab-${name}-${tab.id}`}
        hidden={i !== 0}
      >
        <slot name={tab.id} />
      </div>
    ))
  }
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-tabs]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>(':scope > [role="tabpanel"]'));

    const select = (index: number, focus = false) => {
      tabs.forEach((tab, i) => {
        tab.setAttribute('aria-selected', i === index ? 'true' : 'false');
        tab.tabIndex = i === index ? 0 : -1;
      });
      panels.forEach((panel, i) => {
        panel.hidden = i !== index;
      });
      if (focus) tabs[index].focus();
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => select(i));
      tab.addEventListener('keydown', (event) => {
        const delta = { ArrowRight: 1, ArrowLeft: -1 }[event.key];
        if (delta !== undefined) {
          event.preventDefault();
          select((i + delta + tabs.length) % tabs.length, true);
        } else if (event.key === 'Home') {
          event.preventDefault();
          select(0, true);
        } else if (event.key === 'End') {
          event.preventDefault();
          select(tabs.length - 1, true);
        }
      });
    });
  });
</script>
