---
import '../styles/tokens.css';
import '../styles/landing.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// Prefix internal links with the configured base so the site also works
// when deployed under a sub-path (GitHub project pages).
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const github = 'https://github.com/aloisdeniel/moth';

// Absolute URLs for social cards / canonical (Astro.site is always set in
// astro.config.mjs).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`${base}/og.png`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}/favicon-32.png`} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="wordmark" href={`${base}/`}>moth</a>
        <nav aria-label="Main">
          <a href="#how-it-works" data-anchor>How it works</a>
          <a href="#features" data-anchor>Features</a>
          <a href="#why" data-anchor>Why moth</a>
          <a href="#install" data-anchor>Install</a>
          <a href={`${base}/docs/`}>Docs</a>
          <a href={github}>GitHub</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="wordmark">moth</span>
        <nav aria-label="Footer">
          <a href={github}>GitHub</a>
          <a href={`${github}/blob/main/LICENSE`}>License</a>
          <a href={`${base}/docs/`}>Docs</a>
          <a href={`${base}/docs/changelog/`}>Changelog</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
