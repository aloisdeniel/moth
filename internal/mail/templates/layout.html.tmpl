<div style="font-family: -apple-system, 'Segoe UI', Roboto, sans-serif; max-width: 480px; margin: 0 auto; padding: 24px; color: #1a1a1a;">
  <h2 style="font-size: 18px; margin: 0 0 16px;">{{.Subject}}</h2>
  {{- range .Paragraphs}}
  <p style="font-size: 14px; line-height: 1.6; margin: 0 0 12px;">{{.}}</p>
  {{- end}}
  {{- if .ButtonURL}}
  <p style="margin: 24px 0;">
    <a href="{{.ButtonURL}}" style="background: #1a1a1a; color: #ffffff; text-decoration: none; padding: 10px 20px; border-radius: 6px; font-size: 14px; display: inline-block;">{{.ButtonLabel}}</a>
  </p>
  <p style="font-size: 12px; line-height: 1.6; color: #6b6b6b;">Or open this link: <a href="{{.ButtonURL}}" style="color: #1a1a1a;">{{.ButtonURL}}</a></p>
  {{- end}}
  <p style="font-size: 12px; color: #6b6b6b; margin-top: 24px;">— {{.Project}}</p>
</div>
