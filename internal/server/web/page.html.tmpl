<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex">
  <title>{{.Title}} — {{.Project}}</title>
  <style>
    body { font-family: -apple-system, 'Segoe UI', Roboto, sans-serif; background: #f6f6f4;
           color: #1a1a1a; display: flex; justify-content: center; padding: 48px 16px; margin: 0; }
    main { background: #ffffff; border: 1px solid #e4e4e0; border-radius: 12px;
           padding: 32px; max-width: 380px; width: 100%; }
    h1 { font-size: 18px; margin: 0 0 12px; }
    p { font-size: 14px; line-height: 1.6; margin: 0 0 12px; color: #444; }
    .err { color: #b3261e; }
    label { display: block; font-size: 13px; margin: 16px 0 6px; }
    input[type=password] { width: 100%; box-sizing: border-box; padding: 10px 12px; font-size: 14px;
            border: 1px solid #ccc; border-radius: 8px; }
    button { margin-top: 16px; width: 100%; background: #1a1a1a; color: #fff; border: 0;
             border-radius: 8px; padding: 11px 0; font-size: 14px; cursor: pointer; }
    footer { margin-top: 20px; font-size: 12px; color: #999; text-align: center; }
  </style>
</head>
<body>
  <main>
    <h1>{{.Title}}</h1>
    {{- if .Error}}
    <p class="err">{{.Error}}</p>
    {{- else}}
    <p>{{.Message}}</p>
    {{- end}}
    {{- if .ShowResetForm}}
    <form method="post" action="reset">
      <input type="hidden" name="token" value="{{.Token}}">
      <label for="password">New password</label>
      <input type="password" id="password" name="password" autocomplete="new-password" required>
      <button type="submit">Set new password</button>
    </form>
    {{- end}}
    <footer>{{.Project}}</footer>
  </main>
</body>
</html>
